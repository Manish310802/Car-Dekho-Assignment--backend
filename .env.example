# Primary LLM provider. If unset, falls back to Grok (xAI); if both are
# unset, recommendations still work with a deterministic templated rationale.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Fallback LLM provider (xAI Grok, OpenAI-API compatible)
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# Neon serverless Postgres connection string.
# If unset, the backend uses a local SQLite file so it runs with zero setup.
# Example: postgresql+psycopg://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Comma-separated list of allowed CORS origins (the deployed frontend URL).
CORS_ORIGINS=http://localhost:5173
